# ===========================================
# n8n Environment Variables Template
# ===========================================
# Copy this file to .env.n8n and configure as needed

# n8n Basic Auth
N8N_BASIC_AUTH_USER=n8n_admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_password

# n8n URL (public webhook URL)
N8N_WEBHOOK_URL=https://n8n.yourdomain.com

# n8n Host settings
N8N_HOST=n8n.yourdomain.com
N8N_PROTOCOL=http
N8N_PORT=5678

# Timezone
N8N_TIMEZONE=America/Argentina/Buenos_Aires

# Execution mode: regular, queue
N8N_EXECUTIONS_MODE=regular
